{
  "name": "@cosq-network/qode",
  "version": "1.7.0",
  "type": "module",
  "author": "Benoy Bose <benoybose@cosq.net> (COSQ Network Private Limited)",
  "description": "Multi-provider coding agent CLI with tool use, context compression, and session resume",
  "main": "dist/index.js",
  "bin": {
    "qode": "./dist/index.js"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsc -p tsconfig.build.json && node scripts/copy-assets.mjs",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:ci": "jest -c jest.config.cjs --watchman=false",
    "package:check": "node scripts/check-package.mjs",
    "smoke:cli": "node scripts/smoke-cli.mjs",
    "smoke:install": "node scripts/smoke-packed-install.mjs",
    "verify:production": "npm run build && npm run lint && npm run test:ci && npm run package:check && npm run smoke:cli",
    "verify:release": "npm run verify:production && npm run smoke:install",
    "prepublishOnly": "npm run verify:production",
    "test": "jest -c jest.config.cjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@clack/prompts": "^1.6.0",
    "@google/generative-ai": "^0.21.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "blessed": "^0.1.81",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "fs-extra": "^11.2.0",
    "gpt-tokenizer": "^1.0.0",
    "ignore": "^5.3.2",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "openai": "^4.52.7",
    "ora": "^8.0.0",
    "tiktoken": "^1.0.15",
    "uuid": "^11.1.1",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/blessed": "^0.1.27",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.12",
    "@types/marked-terminal": "^6.1.1",
    "@types/node": "^20.14.0",
    "eslint": "^9.21.0",
    "inquirer": "^9.2.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.25.0"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/",
    "CHANGELOG.md"
  ]
}
